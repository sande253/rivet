# Rivet Development Environment Configuration
# Copy this file to terraform.tfvars and update with your values

# ══════════════════════════════════════════════════════════════════════════════
# AWS Configuration
# ══════════════════════════════════════════════════════════════════════════════

aws_region = "us-east-1"

availability_zones = [
  "us-east-1a",
  "us-east-1b"
]

# ══════════════════════════════════════════════════════════════════════════════
# Bedrock Configuration (RECOMMENDED)
# ══════════════════════════════════════════════════════════════════════════════

# Use AWS Bedrock instead of Anthropic API
# Benefits: No API keys, unified billing, better AWS integration
use_bedrock = true

# Bedrock Model IDs (use these when use_bedrock=true)
draft_model_id         = "anthropic.claude-3-5-haiku-20241022-v1:0"   # Fast, cheap
critic_model_id        = "anthropic.claude-3-5-sonnet-20241022-v2:0"  # Balanced
vision_model_id        = ""                                            # Optional
bedrock_image_model_id = "amazon.titan-image-generator-v2:0"          # Image gen

# ══════════════════════════════════════════════════════════════════════════════
# Anthropic API Configuration (LEGACY - only if use_bedrock=false)
# ══════════════════════════════════════════════════════════════════════════════

# Only required if use_bedrock=false
# anthropic_api_key = "sk-ant-api03-..."

# Legacy model IDs (use these when use_bedrock=false)
# draft_model_id  = "claude-haiku-4-5-20251001"
# critic_model_id = "claude-sonnet-4-6"

# ══════════════════════════════════════════════════════════════════════════════
# Networking Configuration
# ══════════════════════════════════════════════════════════════════════════════

vpc_cidr = "10.0.0.0/16"

public_subnet_cidrs = [
  "10.0.1.0/24",  # us-east-1a
  "10.0.2.0/24"   # us-east-1b
]

private_subnet_cidrs = [
  "10.0.11.0/24",  # us-east-1a
  "10.0.12.0/24"   # us-east-1b
]

# ══════════════════════════════════════════════════════════════════════════════
# EC2 Instance Configuration
# ══════════════════════════════════════════════════════════════════════════════

instance_type = "t3.small"  # 2 vCPU, 2 GB RAM (~$15/month)
# Options: t3.micro, t3.small, t3.medium, t3.large

# Auto Scaling Configuration
min_size         = 1  # Minimum instances (always running)
max_size         = 3  # Maximum instances (scale up to this)
desired_capacity = 1  # Initial number of instances

# ══════════════════════════════════════════════════════════════════════════════
# Container Configuration
# ══════════════════════════════════════════════════════════════════════════════

container_port = 8080  # Port the Flask app listens on

# Docker image tag (updated automatically by CI/CD)
image_tag = "latest"

# ══════════════════════════════════════════════════════════════════════════════
# Bedrock Observability
# ══════════════════════════════════════════════════════════════════════════════

# CloudWatch log retention
bedrock_log_retention_days = 14  # Days to keep Bedrock logs

# CloudWatch alarms
enable_bedrock_alarms = true  # Enable alarms for GenAI metrics

# Alarm thresholds
genai_latency_threshold_ms  = 5000  # Alert if latency > 5 seconds
genai_error_threshold_count = 10    # Alert if > 10 errors per 5 minutes

# ══════════════════════════════════════════════════════════════════════════════
# Cost Optimization Tips
# ══════════════════════════════════════════════════════════════════════════════

# Development Environment:
# - instance_type = "t3.small" (~$15/month)
# - min_size = 1, max_size = 2
# - bedrock_log_retention_days = 7
# - Estimated cost: ~$50-70/month

# Production Environment:
# - instance_type = "t3.medium" (~$30/month)
# - min_size = 2, max_size = 5
# - bedrock_log_retention_days = 30
# - Estimated cost: ~$150-200/month

# ══════════════════════════════════════════════════════════════════════════════
# Quick Start
# ══════════════════════════════════════════════════════════════════════════════

# 1. Copy this file:
#    cp terraform.tfvars.example terraform.tfvars
#
# 2. Update values above (especially AWS region and availability zones)
#
# 3. Enable Bedrock models in AWS Console:
#    - Go to Bedrock → Model access
#    - Enable Claude 3.5 Sonnet, Haiku, and Titan Image Generator
#
# 4. Deploy:
#    terraform init
#    terraform plan
#    terraform apply
#
# 5. Wait for deployment (~30 minutes)
#
# 6. Get ALB URL:
#    terraform output alb_dns_name
#
# 7. Test:
#    curl http://<ALB_DNS>/

