# ══════════════════════════════════════════════════════════════════════════════
# Production Terraform Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars to version control

# ── AWS Configuration ─────────────────────────────────────────────────────────
aws_region = "us-east-1"

# ── Networking ────────────────────────────────────────────────────────────────
vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
database_subnet_cidrs = ["10.0.21.0/24", "10.0.22.0/24"]

# ── SSL/TLS (HTTPS) ───────────────────────────────────────────────────────────
# Leave empty to skip HTTPS setup (will use HTTP only)
# If you have a domain, set it here and configure DNS after deployment
domain_name = ""  # Example: "app.yourdomain.com"
subject_alternative_names = []  # Example: ["www.yourdomain.com"]

# ── Database (RDS PostgreSQL) ─────────────────────────────────────────────────
db_name              = "rivet"
db_username          = "rivetadmin"
db_instance_class    = "db.t4g.micro"  # Smallest: db.t4g.micro, Recommended: db.t4g.small
db_allocated_storage = 20  # GB
db_multi_az          = false  # Set to true for production HA (doubles cost)
db_backup_retention_days = 7  # Days to retain automated backups

# ── Compute (EC2 Auto Scaling) ────────────────────────────────────────────────
instance_type    = "t3.small"  # 2 vCPU, 2 GB RAM
container_port   = 8080
image_tag        = "latest"

# Auto Scaling configuration
min_size         = 2  # Minimum instances (HA requires >= 2)
max_size         = 6  # Maximum instances
desired_capacity = 2  # Initial number of instances

# ── GenAI Configuration ───────────────────────────────────────────────────────
use_bedrock = true  # Use AWS Bedrock (recommended)

# If use_bedrock = false, set this via environment variable:
# export TF_VAR_anthropic_api_key="sk-ant-..."
anthropic_api_key = ""

# Bedrock model IDs
draft_model_id         = "anthropic.claude-3-5-sonnet-20241022-v2:0"
critic_model_id        = "anthropic.claude-3-5-sonnet-20241022-v2:0"
vision_model_id        = "anthropic.claude-3-5-sonnet-20241022-v2:0"
bedrock_image_model_id = "amazon.titan-image-generator-v2:0"

# ── Monitoring ────────────────────────────────────────────────────────────────
bedrock_log_retention_days = 30  # CloudWatch log retention
enable_bedrock_alarms      = true  # Enable CloudWatch alarms

# Alarm thresholds
genai_latency_threshold_ms  = 5000  # Alert if GenAI latency > 5 seconds
genai_error_threshold_count = 5     # Alert if > 5 errors in 5 minutes

# ══════════════════════════════════════════════════════════════════════════════
# Cost Optimization Tips
# ══════════════════════════════════════════════════════════════════════════════
#
# 1. Use single NAT Gateway (not HA) to save ~$32/month:
#    In main.tf, set: single_nat_gateway = true
#
# 2. Reduce min_size to 1 during off-hours (not HA):
#    min_size = 1
#
# 3. Use Reserved Instances (1-year commitment) for ~40% savings
#
# 4. Disable Multi-AZ RDS (not HA):
#    db_multi_az = false
#
# Estimated monthly cost:
# - 2 × t3.small EC2: ~$30
# - 1 × db.t4g.micro RDS: ~$15
# - 2 × NAT Gateway: ~$65 (or $32 with single NAT)
# - 1 × ALB: ~$20
# - Data transfer: ~$10
# Total: ~$140/month (or ~$110 with single NAT)
#
# ══════════════════════════════════════════════════════════════════════════════
