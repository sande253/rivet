# Rivet Application Environment Variables
# Copy this file to .env and update with your values

# ══════════════════════════════════════════════════════════════════════════════
# Flask Configuration
# ══════════════════════════════════════════════════════════════════════════════

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production

# ══════════════════════════════════════════════════════════════════════════════
# Database Configuration
# ══════════════════════════════════════════════════════════════════════════════

# SQLite (default for local development)
DATABASE_URL=sqlite:///instance/rivet.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/rivet

# ══════════════════════════════════════════════════════════════════════════════
# AI Model Configuration
# ══════════════════════════════════════════════════════════════════════════════

# Use AWS Bedrock (recommended) or Anthropic API
USE_BEDROCK=true

# If USE_BEDROCK=false, provide Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Bedrock Model IDs (when USE_BEDROCK=true)
DRAFT_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
CRITIC_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
VISION_MODEL_ID=
BEDROCK_IMAGE_MODEL_ID=amazon.titan-image-generator-v2:0

# Legacy Anthropic Model IDs (when USE_BEDROCK=false)
# DRAFT_MODEL_ID=claude-haiku-4-5-20251001
# CRITIC_MODEL_ID=claude-sonnet-4-6

# ══════════════════════════════════════════════════════════════════════════════
# AWS Configuration (for Bedrock and S3)
# ══════════════════════════════════════════════════════════════════════════════

AWS_REGION=us-east-1
# AWS credentials are read from ~/.aws/credentials or IAM role (EC2)

# ══════════════════════════════════════════════════════════════════════════════
# Storage Configuration
# ══════════════════════════════════════════════════════════════════════════════

# Local uploads folder
UPLOAD_FOLDER=static/uploads

# S3 bucket (for production)
S3_BUCKET=

# Max upload size in MB
MAX_CONTENT_LENGTH_MB=16

# ══════════════════════════════════════════════════════════════════════════════
# GenAI Configuration
# ══════════════════════════════════════════════════════════════════════════════

# Enable/disable GenAI tips generation
GENAI_ENABLED=true

# Cache TTL in seconds (5 minutes)
GENAI_CACHE_TTL=300

# Circuit breaker settings
GENAI_FAILURE_THRESHOLD=5
GENAI_CIRCUIT_TIMEOUT=300

# ══════════════════════════════════════════════════════════════════════════════
# Environment Mode
# ══════════════════════════════════════════════════════════════════════════════

# local = PIL-based mockup generation (development)
# production = Bedrock Titan image generation (production)
ENVIRONMENT=local

# ══════════════════════════════════════════════════════════════════════════════
# Quick Start Configurations
# ══════════════════════════════════════════════════════════════════════════════

# Local Development (Anthropic API)
# ----------------------------------
# USE_BEDROCK=false
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ENVIRONMENT=local
# GENAI_ENABLED=true

# Local Development (Bedrock)
# ---------------------------
# USE_BEDROCK=true
# AWS_REGION=us-east-1
# ENVIRONMENT=local
# GENAI_ENABLED=true
# (Requires AWS credentials configured)

# Production (AWS EC2 + Bedrock)
# -------------------------------
# USE_BEDROCK=true
# AWS_REGION=us-east-1
# ENVIRONMENT=production
# GENAI_ENABLED=true
# S3_BUCKET=your-bucket-name
# (Uses IAM role for credentials)
